# Copy this file to .env and fill in your real values.
# These map to the ${...} placeholders in application.properties.

# Supabase connection string, e.g.
# jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
DB_URL=jdbc:postgresql://localhost:5432/bookify
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Secret สำหรับลงนาม JWT (HS256) — ต้องยาวอย่างน้อย 32 ตัวอักษร (256-bit)
# สร้างใหม่ได้ด้วย: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
